<?xml version="1.0" encoding="UTF-8"?>
<plugin version="1">
  <name> Signalk_notes_opencpn </name>
  <version> 1.0.0.1 </version>
  <release> 1 </release>
  <summary> Plugin to show notes created by SignalK plugins on the map </summary>

  <api-version> 1.20 </api-version>
  <open-source> yes </open-source>
  <author> Dirk Behrendt </author>
  <source> https://github.com/formifan2026/signalk-notes-opencpn </source>

  <description>
    signalk_notes_opencpn Plugin is used to show notes from SignalK created by SignalK plugins like 'Garmin Active Captain Resource' or 'EuRIS (European River Information Services)' on the map
  </description>

  <target>android-armhf</target>
  <build-target>android</build-target>
  <build-gtk></build-gtk>
  <target-version>16</target-version>
  <target-arch>armhf</target-arch>
  <tarball-url>
    https://dl.cloudsmith.io/public/formifan2002/signalk-notes-opencpn-alpha/raw/names/signalk_notes_opencpn_pi-1.0.0.1-android-armhf-16-android-armhf-tarball/versions/1.0.0.1+276.4f3a567/signalk_notes_opencpn_pi-1.0.0.1-android-armhf-16-android-armhf.tar.gz
  </tarball-url>
  <info-url> https://github.com/formifan2002/signalk-notes-opencpn </info-url>
</plugin>
